VERSION=0.3.11-alpha
NODE_ENV=development


############# Common ###############
## LOGGER
LOG_LEVEL=debug
CREATE_LOG_FILE=false

# POSTGRES
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker
POSTGRES_DB=vantik

# Nest run in docker, change host to database container name
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=vantik

REDIS_URL=localhost
REDIS_PORT=6379
REDIS_TLS_DISABLED=true

FRONTEND_HOST=http://localhost:3000
BACKEND_HOST=http://localhost:3001
BACKEND_URL=http://localhost:3001

OAUTH_CALLBACK_URL=${FRONTEND_HOST}/api/v1/oauth/callback

# Passkeys are bound to the hostname in FRONTEND_HOST, so an install reached on
# a different domain than it was registered on will not see its passkeys.
# Set this to false to stop a passkey from creating a brand new account: people
# then arrive through an invite or a login code and add a passkey afterwards.
PASSKEY_SIGNUP_ENABLED=true
############# Server ###############
# Prisma database connection
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}?schema=${DB_SCHEMA}&sslmode=prefer
REPLICATION_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

BACKEND_PORT=3001
SUPERTOKEN_CONNECTION_URI=http://localhost:3567

# These are used by server to talk to typesense
TYPESENSE_API_KEY=random_API_key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# Setting these will save the uploaded files in that bucket
STORAGE_PROVIDER=

BUCKET_NAME=
GCP_SERVICE_ACCOUNT_FILE=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email settings
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_DEFAULT_FROM=

# Used in title generation, Summarize and in delegation suggestions
OPENAI_API_KEY=

LOCAL_MODEL=gemma2:2b
OLLAMA_HOST=http://localhost:11434

############# Frontend ###############
# The browser reads these from the server at /api/v1/config when the app loads,
# so they take effect on container restart - no rebuild needed.

# Origin the browser reaches the server on, for the websocket connection. The
# websocket is not proxied through the webapp, so this cannot be a path.
# Everything else the frontend calls goes through /api on its own origin.
NEXT_PUBLIC_BACKEND_HOST=${BACKEND_HOST}

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# You need to set your domain if self-hosted
PUBLIC_ATTACHMENT_URL=http://localhost:3000/api

# You can add your sentry to get the errors from the application.
# Leave empty to disable; this must be a real Sentry DSN, not a host.
NEXT_PUBLIC_SENTRY_DSN=

############# Trigger.dev ###############
TRIGGER_PORT=3030
TRIGGER_COMMON_ID=clyofc7dn0000o33e4sup590l

TRIGGER_TOKEN=27192e6432564f4788d55c15131bd5ac
TRIGGER_ACCESS_TOKEN=tr_pat_${TRIGGER_TOKEN}
TRIGGER_API_URL=http://localhost:3030

TRIGGER_DB=trigger
TRIGGER_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}/${TRIGGER_DB}
