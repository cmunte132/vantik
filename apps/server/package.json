    "@nestjs/testing": "^11.1.0",
    "@swc/cli": "^0.1.65",
    "@swc/core": "^1.3.105",
    "@vantikhq/eslint-config": "workspace:*",
    "@vantikhq/typescript-config": "workspace:*",
    "@types/bcrypt": "5.0.2",
    "@types/body-parser": "^1.19.5",
    "@types/chance": "1.1.6",
    "@types/cookie": "^0.6.0",
