{
  "name": "server",
  "version": "0.3.10",
  "description": "Vantik server",
  "author": "Vantik",
  "private": true,
  "keywords": [
    "nestjs",
    "prisma",
    "prisma client",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vantikhq/server.git"
  },
  "bugs": {
    "url": "https://github.com/vantikhq/server.git/issues"
  },
  "scripts": {
    "build": "prisma generate && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start-prod": "pnpm run migrate:deploy && pnpm run generate && node dist/src/main",
    "start-prod-with-prisma": "pnpm run start-prod && pnpm prisma:studio",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migrate": "prisma migrate dev",
    "migrate:dev:create": "prisma migrate dev --create-only",
    "migrate:reset": "prisma migrate reset",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "migrate:resolve": "prisma migrate resolve",
    "prisma:studio": "prisma studio",
    "generate": "prisma generate",
    "db:init-resources": "pnpm run migrate && pnpm run generate",
    "trigger-deploy": "npx trigger.dev@3.3.13 deploy --self-hosted",
    "trigger-dev": "npx trigger.dev@3.3.13 dev"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.16",
    "@ai-sdk/openai": "^4.0.16",
    "@aws-sdk/client-s3": "^3.712.0",
